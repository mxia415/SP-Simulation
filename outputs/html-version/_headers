/
  Cache-Control: no-store

/*.html
  Cache-Control: no-store

/app-bundle.js
  Cache-Control: public, max-age=31536000, immutable

/styles.css
  Cache-Control: public, max-age=31536000, immutable

/assets/*.glb
  Cache-Control: public, max-age=31536000, immutable

/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*.wasm
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm

/assets/paths/*
  Cache-Control: no-cache
